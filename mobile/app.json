{
  "expo": {
    "name": "UPKEM LABS",
    "slug": "upkem-labs-b2b",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/pharma_logo.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/pharma_logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#0B2618"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.upkemlabs.b2b",
      "infoPlist": {
        "NSCameraUsageDescription": "UPKEM LABS needs camera access for document scanning.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.upkemlabs.b2b",
      "adaptiveIcon": {
        "foregroundImage": "./assets/pharma_logo.jpeg",
        "backgroundColor": "#0B2618"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "7d5de68f-77b5-46b1-af48-127447bcb46c"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
